# =============================================================================
# AdsMaster Production Environment - Hostinger VPS
# =============================================================================
# Copy this file to .env and fill in your values
# NEVER commit this file with real credentials!
# =============================================================================

# =============================================================================
# DATABASE (Hostinger PostgreSQL)
# =============================================================================
# Format: postgresql://username:password@host:port/database
DATABASE_URL=postgresql://adsmaster_user:YOUR_STRONG_PASSWORD@localhost:5432/adsmaster

# Legacy variables (keep for compatibility)
POSTGRES_USER=adsmaster_user
POSTGRES_PASSWORD=YOUR_STRONG_PASSWORD
POSTGRES_DB=adsmaster

# =============================================================================
# REDIS (optional - for rate limiting, caching)
# =============================================================================
# Install Redis on VPS: sudo apt install redis-server
REDIS_URL=redis://localhost:6379

# =============================================================================
# JWT AUTHENTICATION (CHANGE THIS!)
# =============================================================================
# Generate a secure key: openssl rand -hex 32
JWT_SECRET=GENERATE_A_SECURE_64_CHARACTER_STRING_HERE

# =============================================================================
# GOOGLE ADS API
# =============================================================================
GOOGLE_ADS_DEVELOPER_TOKEN=your_developer_token
GOOGLE_ADS_CLIENT_ID=your_client_id.apps.googleusercontent.com
GOOGLE_ADS_CLIENT_SECRET=your_client_secret
GOOGLE_ADS_REDIRECT_URI=https://yourdomain.com/auth/google-ads/callback

# =============================================================================
# META ADS API (Facebook/Instagram)
# =============================================================================
META_APP_ID=your_meta_app_id
META_APP_SECRET=your_meta_app_secret
META_REDIRECT_URI=https://yourdomain.com/auth/meta/callback

# =============================================================================
# AI PROVIDERS
# =============================================================================
GEMINI_API_KEY=your_gemini_api_key

# Optional backups
# OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...

# =============================================================================
# GCP / VERTEX AI / BIGQUERY ML
# =============================================================================
GCP_PROJECT_ID=adsmaster-492611
GCP_LOCATION=us-central1
GOOGLE_APPLICATION_CREDENTIALS=/home/adsmaster/credentials/gcp-service-account.json
BIGQUERY_DATASET=adsmaster_ml

# =============================================================================
# STRIPE (for billing)
# =============================================================================
# Get from: https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_live_...
STRIPE_PUBLISHABLE_KEY=pk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...

# =============================================================================
# EMAIL (Resend)
# =============================================================================
RESEND_API_KEY=your_resend_api_key
RESEND_FROM_EMAIL=noreply@app.scalabl.io

# =============================================================================
# APP SETTINGS
# =============================================================================
DEBUG=false
ENVIRONMENT=production

# Your domain (no trailing slash)
API_URL=https://api.yourdomain.com
WEB_URL=https://yourdomain.com
NEXT_PUBLIC_API_URL=https://api.yourdomain.com

# =============================================================================
# CORS ORIGINS (comma-separated)
# =============================================================================
CORS_ORIGINS=https://yourdomain.com,https://www.yourdomain.com
