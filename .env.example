# AdsMaster Environment Variables
# Copy this to .env and fill in your values

# =============================================================================
# DATABASE (PostgreSQL)
# =============================================================================
POSTGRES_USER=adsmaster
POSTGRES_PASSWORD=your-secure-password-here
POSTGRES_DB=adsmaster
DATABASE_URL=postgresql+asyncpg://adsmaster:your-secure-password-here@postgres:5432/adsmaster

# =============================================================================
# REDIS
# =============================================================================
REDIS_URL=redis://redis:6379

# =============================================================================
# JWT AUTHENTICATION
# =============================================================================
JWT_SECRET=your-super-secret-jwt-key-change-in-production-minimum-32-chars

# =============================================================================
# GOOGLE ADS API
# =============================================================================
GOOGLE_ADS_DEVELOPER_TOKEN=your-developer-token
GOOGLE_ADS_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_ADS_CLIENT_SECRET=your-client-secret
GOOGLE_ADS_REDIRECT_URI=https://yourdomain.com/auth/google-ads/callback

# =============================================================================
# META ADS API
# =============================================================================
META_APP_ID=your-app-id
META_APP_SECRET=your-app-secret
META_REDIRECT_URI=https://yourdomain.com/auth/meta/callback

# =============================================================================
# AI PROVIDERS (at least one required)
# =============================================================================
GEMINI_API_KEY=your-gemini-api-key
OPENAI_API_KEY=your-openai-api-key
ANTHROPIC_API_KEY=your-anthropic-api-key

# =============================================================================
# APP SETTINGS
# =============================================================================
DEBUG=false
API_URL=https://api.yourdomain.com
WEB_URL=https://yourdomain.com
NEXT_PUBLIC_API_URL=https://api.yourdomain.com
