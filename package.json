{
  "name": "adsmaster",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "lint": "turbo lint",
    "test": "turbo test",
    "dev:web": "turbo dev --filter=web",
    "dev:api": "cd apps/api && poetry run uvicorn app.main:app --reload --port 8000",
    "db:migrate": "npx supabase db push",
    "db:reset": "npx supabase db reset"
  },
  "devDependencies": {
    "@types/node": "^25.3.5",
    "turbo": "^2.8.14",
    "typescript": "^5.9.3"
  },
  "packageManager": "npm@10.0.0",
  "engines": {
    "node": ">=20"
  }
}
